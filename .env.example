DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
JWT_SECRET="replace-with-a-long-random-secret"
GOOGLE_CLIENT_ID="y121838754048-vcm0h37e2kre1uaq4ac1mgmtapvm54rr.apps.googleusercontent.com"

# Email OTP through Resend. Without RESEND_API_KEY, local development logs OTPs in the backend terminal.
RESEND_API_KEY="re_xxxxxxxxx"
OTP_EMAIL_FROM="Dream Stitch <verify@your-domain.com>"
OTP_TTL_MINUTES="10"

# Optional: used only by npm run seed to create/update an admin account.
